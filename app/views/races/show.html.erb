<div class="container">

  <div class="row">
    <div class="col mt-5">
      <h1 class="text-center text-dark"><%= @race.name %></h1>
    </div>
  </div>

  <%= render 'shared/owner_block' %>
  <%= render 'shared/races_show_buttons' %>

  <div class="row px-4 mt-3 mb-5">
    <div class="col rt-shadow rt-rounded p-0">
      <div id="map"
      class="rt-rounded rt-map"
      style="height: 350px;"
	  data-controller="map"
	  data-map-view-value="show"
      data-markers="<%= @markers.to_json %>"
      data-mapbox-api-key="<%= ENV['MAPBOX_API_KEY'] %>">
      </div>
    </div>
  </div>

  <div class="row">
    <h4 class="text-start ms-4">Información</h4>
  </div>

  <div class="row px-4">
    <div class="col rt-rounded rt-shadow bg-light p-3">
      <div class="row my-3">
        <div class="col px-4">
          <p class="mb-0"><strong>Info:</strong></p>
          <p class="text-break"><%= @race.description %></p>
        </div>
      </div>

      <div class="row d-flex justify-content-around px-4 my-3 my-md-0">
        <div class="col col-10 col-md-auto border-start border-info border-2 mb-2">
          <p class="mb-0"><strong>Distance:</strong></p>
          <p class="text-break mb-0"><%= @race.length %> km.</p>
        </div>

        <div class="col col-10 col-md-auto border-start border-info border-2 mb-2">
          <p class="mb-0"><strong>Where:</strong></p>
          <p class="text-break mb-0"><%= @race.meet_point %></p>
        </div>

        <div class="col col-10 col-md-auto border-start border-info border-2 mb-2">
          <p class="mb-0"><strong>When:</strong></p>
          <p class="text-break mb-0"><%= @race.start_date.strftime("%d %b of %Y, %H:%M") %></p>
        </div>
      </div>
      
      <% if user_signed_in? && @runners_id.exclude?(current_user.id) %>
        <div class="row mt-3 justify-content-center">
          <div class="col-auto">
            <%= link_to "Join this race",
            race_runners_path(@race),
            data: { turbo_method: :post },
            class: "btn rt-btn rt-hili-brand" %>
          </div>
        </div>
      <% elsif user_signed_in? == false %>
        <div class="row mt-3 justify-content-center">
          <div class="col-auto">
            <%= link_to "Join this race",
            new_user_session_path,
            class: "btn rt-btn rt-hili-brand" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>


  <div class="row px-4 mt-5">
    <h4 class="text-start ms-4">Participantes</h4>
  </div>

  <div class="row px-4">
    <div class="rt-rounded rt-shadow bg-light p-3">

      <div class="col">
        <%= render 'shared/assistants' %>
      </div>
    </div>
  </div>

  <div class="row px-4 mt-5">
    <h4 class="text-start ms-4">Mensajes</h4>
  </div>

  <div class="row px-4">
    <div class="rt-rounded rt-shadow bg-light mb-5 p-0">
      <% if @conversation && @is_participant %>
        <%= render "conversations/show" %>
      <% elsif @conversation %>
        <p class="text-center text-muted p-3">Unite a la carrera para acceder al chat.</p>
      <% else %>
        <p class="text-center text-muted p-3">Chat no disponible.</p>
      <% end %>
    </div>
  </div>
</div>
