<% if @runners.any? %>
  <div class="row assistants-list row-cols-2 row-cols-sm-3 row-cols-md-4 g-3">
    <% @runners.each do |runner| %>
      <% user = User.find(runner.user_id) %>

      <div class="col">
        <div class="d-flex align-items-center justify-content-center">

          <% profile_url = (user_signed_in? && user.id == current_user.id) ? profile_index_path : profile_path(user) %>
          <%= link_to profile_url do %>
            <% if user.photo.attached? %>
              <%= image_tag user.avatar_url(size: 150),
                class: "avatar"
              %>
            <% else %>
              <%= image_tag "logo.png",
              alt:"RunTogether logo",
              class: "avatar rt-profile-no-photo" %>
            <% end %>
          <% end %>

          <p class="ms-3 mb-0">
            <%= link_to User.find(runner.user_id).name.split[0],
              profile_path(user),
              class: "text-decoration-none text-dark assistant-name-link"
            %>
          </p>

        </div>
      </div>

    <% end %>
  </div>
<% end %>
